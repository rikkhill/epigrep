      "ts": 1,
      "typ": "warning",
      "attrs": {
        "user_id": "u2"
      }
    },
    {
      "partition": "a",
      "ts": 2,
      "typ": "B"
    },
    {
      "partition": "b",
      "ts": 0,
      "typ": "A",
      "attrs": {
        "user_id": "u1"
      }
    },
    {
      "partition": "b",
      "ts": 1,
      "typ": "warning",
      "attrs": {
        "user_id": "u1"
      }
    },
    {
      "partition": "b",
      "ts": 2,
      "typ": "B"
    }
  ],
